.page-title { font-size: 40rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 24rpx; }
.load-more { text-align: center; padding: 32rpx 0; }
.load-text { font-size: 26rpx; color: var(--color-accent); padding: 12rpx 32rpx; border-radius: 20rpx; background: var(--color-accent-light); }
.safe-bottom { height: calc(env(safe-area-inset-bottom) + 40rpx); }
