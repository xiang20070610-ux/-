/* 灵感页面样式 */
.mood-bar {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: var(--color-hint);
  margin-bottom: 14rpx;
  display: block;
}

.mood-scroll { white-space: nowrap; }

.mood-list { display: flex; gap: 12rpx; padding: 4rpx 0; }

.mood-chip {
  display: inline-flex;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  font-size: 24rpx;
  color: var(--color-secondary);
  transition: all 0.2s;
  white-space: nowrap;
}

.mood-chip.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

/* 灵感卡片 */
.inspire-card {
  background: var(--color-white);
  border-radius: 28rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.05);
  margin-bottom: 32rpx;
}

.card-label {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  font-size: 24rpx;
  color: var(--color-hint);
}

.label-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-accent);
  margin-right: 10rpx;
}

.activity-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 20rpx 0;
}

.activity-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.activity-title-xl {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.activity-description {
  font-size: 28rpx;
  color: var(--color-secondary);
  line-height: 1.6;
  margin-bottom: 24rpx;
  max-width: 500rpx;
}

.activity-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--color-hint);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--color-hint);
  background: var(--color-bg);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.btn-secondary, .btn-ai {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  transition: all 0.2s;
}

.btn-secondary {
  background: var(--color-bg);
  color: var(--color-primary);
  border: 2rpx solid var(--color-border);
}

.btn-ai {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-secondary:active, .btn-ai:active { opacity: 0.8; transform: scale(0.98); }

.action-btns {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  font-size: 22rpx;
  color: var(--color-hint);
}

.action-btn text:first-child { font-size: 36rpx; }

/* 加载区域 */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--color-hint);
}

/* 历史推荐 */
.history-section { margin-top: 8rpx; }

.history-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: var(--color-white);
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  max-width: 48%;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.history-title {
  font-size: 24rpx;
  color: var(--color-secondary);
  max-width: 180rpx;
}
