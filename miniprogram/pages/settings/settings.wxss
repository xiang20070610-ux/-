.page-title { font-size: 40rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 28rpx; }

.settings-section { background: var(--color-white); border-radius: 20rpx; padding: 8rpx 0; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); overflow: hidden; }
.section-label { font-size: 26rpx; color: var(--color-hint); padding: 16rpx 24rpx 8rpx; display: block; }

.setting-item { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid var(--color-border); }
.setting-item:last-child { border-bottom: none; }
.setting-item:active { background: var(--color-bg); }

.setting-left { display: flex; align-items: center; flex: 1; }
.setting-icon { font-size: 32rpx; margin-right: 16rpx; }
.setting-label { font-size: 28rpx; color: var(--color-primary); }
.setting-desc { font-size: 22rpx; color: var(--color-hint); margin-left: 12rpx; }
.setting-arrow { font-size: 32rpx; color: var(--color-hint); }
.setting-value { font-size: 26rpx; color: var(--color-hint); }
.cache-size { font-size: 24rpx; color: var(--color-hint); margin-right: 8rpx; }
