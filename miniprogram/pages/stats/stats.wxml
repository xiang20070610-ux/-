<!-- 我的页面 - 数据统计 -->
<view class="page-container {{darkMode ? 'dark' : ''}}">
  <!-- 用户头部 -->
  <view class="profile-header fade-in">
    <view class="avatar">
      <text>😊</text>
    </view>
    <text class="greeting">生活需要一点灵感</text>
  </view>

  <!-- 核心数据 -->
  <view class="data-cards fade-in">
    <view class="data-card">
      <text class="data-num">{{overview.monthly_completions || 0}}</text>
      <text class="data-label">本月完成</text>
    </view>
    <view class="data-card">
      <text class="data-num">{{overview.total_favorites || 0}}</text>
      <text class="data-label">收藏活动</text>
    </view>
    <view class="data-card">
      <text class="data-num">{{overview.total_checkin_days || 0}}</text>
      <text class="data-label">打卡天数</text>
    </view>
    <view class="data-card">
      <text class="data-num">{{overview.streak_days || 0}}</text>
      <text class="data-label">连续打卡</text>
    </view>
  </view>

  <!-- 最爱分类 -->
  <view class="fav-category fade-in" wx:if="{{overview.favorite_category}}">
    <text class="section-label">最喜欢的分类</text>
    <view class="fav-cat-card">
      <text class="fc-icon">{{overview.favorite_category.icon || '📌'}}</text>
      <view class="fc-info">
        <text class="fc-name">{{overview.favorite_category.name}}</text>
        <text class="fc-count">收藏了 {{overview.favorite_category.cnt}} 次</text>
      </view>
    </view>
  </view>

  <!-- 本周统计 -->
  <view class="weekly-stats fade-in" wx:if="{{overview.weekly_stats}}">
    <text class="section-label">本周活动</text>
    <view class="week-bar">
      <view class="week-item" wx:for="{{overview.weekly_stats}}" wx:key="day">
        <text class="week-day">{{item.day}}</text>
        <view class="bar-wrap">
          <view class="bar-fill" style="height: {{item.completions * 20}}rpx; min-height: {{item.completions > 0 ? 8 : 4}}rpx;"></view>
        </view>
        <text class="week-num">{{item.completions}}</text>
        <view class="week-check" wx:if="{{item.checked}}">
          <text>💝</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section fade-in">
    <view class="menu-item" bind:tap="navigateToFavorites">
      <text class="menu-icon">❤️</text>
      <text class="menu-title">我的收藏</text>
      <text class="menu-badge" wx:if="{{overview.total_favorites > 0}}">{{overview.total_favorites}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="navigateToHistory">
      <text class="menu-icon">🕐</text>
      <text class="menu-title">浏览记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="navigateToCheckin">
      <text class="menu-icon">💝</text>
      <text class="menu-title">情侣打卡</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="navigateToLottery">
      <text class="menu-icon">🎰</text>
      <text class="menu-title">活动抽签</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bind:tap="navigateToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-title">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
